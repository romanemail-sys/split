{
  "expo": {
    "name": "Location Tracker",
    "slug": "location-tracker",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "scheme": "location-tracker",
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.romanp.locationtracker",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "com.romanp.locationtracker",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to record your location history.",
          "locationAlwaysAndWhenInUsePermission": "Used to record your location in the background so your route is tracked while the app is closed.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
